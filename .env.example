# TrustedOSS Portal — example environment file.
# Copy to `.env` and fill in real values:
#   cp .env.example .env

# ---------- Application ----------
APP_ENV=dev
LOG_LEVEL=INFO
# Comma-separated list. Production must enumerate origins explicitly.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---------- Edge / TLS (production: docker-compose.yml + Traefik) ----------
# DOMAIN powers Traefik's Host(`...`) rule. For localhost dev this stays
# empty (the dev compose overlay does not run Traefik).
DOMAIN=
# Contact address Let's Encrypt uses for expiry notices and rate-limit
# escalation. Required when DOMAIN is set and the public URL is https://;
# scripts/install.sh prompts for it. Leave empty for HTTP-only / local.
TLS_EMAIL=
# Traefik log level: DEBUG | INFO | WARN | ERROR. INFO is the safe default.
TRAEFIK_LOG_LEVEL=INFO
# IMAGE_TAG pins the trustedoss-portal/* container tags pulled by the
# production compose stack. Bump this on every release; never use :latest.
IMAGE_TAG=2.0.0

# ---------- Database ----------
# Two ways to configure the DB connection (resolved in core.config.database_url):
#   1. DATABASE_URL — full DSN, used by docker-compose dev/prod (default path).
#   2. DB_USER / DB_PASSWORD / DB_HOST / DB_NAME (+ optional DB_PORT) — composed
#      at runtime. Used by the GCP Cloud Run module so DB_PASSWORD can be sourced
#      from Secret Manager without templating the URL through Terraform.
# DATABASE_URL wins when both are set.
DATABASE_URL=postgresql+asyncpg://trustedoss:trustedoss@postgres:5432/trustedoss
# DB_USER=trustedoss
# DB_PASSWORD=trustedoss
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=trustedoss
POSTGRES_USER=trustedoss
POSTGRES_PASSWORD=trustedoss
POSTGRES_DB=trustedoss

# ---------- Redis / Celery ----------
REDIS_URL=redis://redis:6379/0

# ---------- Auth ----------
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- Dependency-Track ----------
# Bundled DT (docker-compose.dt.yml overlay) ships dependencytrack/apiserver:4.13.2.
# DT 4.13 picks up vulnerability data from OSV.dev across 8 ecosystems
# (npm + Maven + PyPI + RubyGems + crates.io + Go + Packagist + NuGet) and
# falls back to NVD via the v2 API.
#
# First-time bootstrap (one-off — see docs/admin/dt-overlay.md when it lands):
#   1. docker-compose -f docker-compose.dev.yml -f docker-compose.dt.yml up -d
#   2. Visit http://localhost:8080 → log in admin / admin → set a new password.
#   3. Administration → Vulnerability Sources → enable the 8 OSV ecosystems.
#      Mirror sync runs in the background (~1 hr for Maven, less for others).
#   4. Administration → Access Management → Teams → "Automation" → copy the
#      API key, paste it into your local .env (NOT this file), then bounce
#      backend + celery-worker.
DT_URL=http://dtrack-api:8080
DT_API_KEY=your-dt-api-key

# ---------- Workspace / ORT ----------
WORKSPACE_HOST_PATH=/opt/trustedoss/workspace
ORT_RULES_PATH=/opt/trustedoss/ort/rules.kts

# ---------- Notifications ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# ---------- OAuth (demo SaaS only) ----------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- Jira (optional, stub by default) ----------
JIRA_ENABLED=false
JIRA_URL=
JIRA_TOKEN=
